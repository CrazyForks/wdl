{
  "metricPrefix": "wdl",
  "requestMetricFamilies": [
    "requests",
    "request_duration_ms",
    "request_errors"
  ],
  "requestMetricLabels": [
    "route",
    "service",
    "status"
  ],
  "cardinalityWarnLimit": 100,
  "prometheusContentType": "text/plain; version=0.0.4; charset=utf-8",
  "labelEscapes": [
    { "raw": "a\\b", "escaped": "a\\\\b" },
    { "raw": "a\nb", "escaped": "a\\nb" },
    { "raw": "a\rb", "escaped": "a\\rb" },
    { "raw": "a\"b", "escaped": "a\\\"b" },
    { "raw": "\r\n\"\\", "escaped": "\\r\\n\\\"\\\\" }
  ],
  "logEnvelope": {
    "orderedKeys": ["ts", "service", "level", "event"],
    "timestampShape": "0000-00-00T00:00:00.000Z",
    "levels": [
      { "name": "debug", "priority": 10, "stream": "stdout" },
      { "name": "info", "priority": 20, "stream": "stdout" },
      { "name": "warn", "priority": 30, "stream": "stdout" },
      { "name": "error", "priority": 40, "stream": "stderr" }
    ]
  }
}
