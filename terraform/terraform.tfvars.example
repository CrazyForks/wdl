region      = "ap-east-1"
name_prefix = "wdl-test"

platform_domain = "*.wdl.sh"
admin_host     = "api.wdl.dev"

vpc_id = "vpc-xxxxxxxxxxxxxxxxx"

private_subnet_ids = [
  "subnet-xxxxxxxxxxxxxxxxx",
  "subnet-yyyyyyyyyyyyyyyyy",
  "subnet-zzzzzzzzzzzzzzzzz",
]

alb_https_listener_arn = "arn:aws:elasticloadbalancing:ap-east-1:123456789012:listener/app/example/aaaaaaaaaaaaaaaa/bbbbbbbbbbbbbbbb"
alb_security_group_id  = "sg-xxxxxxxxxxxxxxxxx"

d1_test_hooks_enabled = false
do_test_hooks_enabled = false

# Optional assets CDN. Leave both empty to skip CloudFront.
assets_cdn_domain              = ""
assets_cdn_acm_certificate_arn = ""
