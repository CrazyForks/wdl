using Workerd = import "/workerd/workerd.capnp";

# system-runtime: one workerd, three sockets.
#   :8081 — loader (workerLoader for dynamic __system__-ns workers)
#   :8088 — internal dispatch (scheduled, queued, workflows)
#   :8082 — control (static worker carrying the platform control plane)
#
# All four workers share a single `network` service with private+public
# reach. Loaded __system__ workers inheriting this is the privilege
# boundary vs user-runtime's allow=["public"]-only `public-network`.

const config :Workerd.Config = (
  services = [
    (name = "loader", worker = .loaderWorker),
    (name = "control", worker = .controlWorker),
    (name = "auth", worker = .authWorker),
    (name = "tail-worker", worker = .tailWorker),
    (name = "do-owner-network", worker = .doOwnerNetworkWorker),
    (name = "d1-runtime", external = (address = "d1-runtime:8787", http = ())),
    (name = "do-runtime", external = (address = "do-runtime:8788", http = ())),
    (name = "workflows", external = (address = "workflows:9120", http = ())),

    # Shared outbound for loader/control/auth/tail plus loaded __system__ workers.
    (name = "network", network = (
      allow = ["private", "public"],
      tlsOptions = (trustBrowserCas = true),
    )),
  ],

  sockets = [
    (name = "loader", address = "*:8081", http = (), service = "loader"),
    (name = "internal", address = "*:8088", http = (), service = (name = "loader", entrypoint = "internal")),
    (name = "control", address = "*:8082", http = (), service = "control"),
    # auth is JSRPC-only — reachable through control's `AUTH` service
    # binding, never published as a socket.
  ],
);

const loaderWorker :Workerd.Worker = (
  modules = [
    (name = "worker", esModule = embed "index.js"),
    (name = "runtime-internal", esModule = embed "internal.js"),
    (name = "runtime-lib", esModule = embed "lib.js"),
