  compatibilityDate = "2026-04-24",
  globalOutbound = "network",
  bindings = [
    (name = "WDL_INTERNAL_AUTH_TOKEN", fromEnvironment = "WDL_INTERNAL_AUTH_TOKEN"),
  ],
);

