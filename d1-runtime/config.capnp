using Workerd = import "/workerd/workerd.capnp";

const config :Workerd.Config = (
  services = [
    (name = "d1-runtime", worker = .d1RuntimeWorker),
    # Durable Object SQL state must use persistent localDisk storage. Do not
    # switch this to memory: D1 database files live under this disk service.
    (name = "d1-storage", disk = (path = "/data/d1", writable = true)),
    (name = "network", network = (
      allow = ["private", "public"],
      tlsOptions = (trustBrowserCas = true),
    )),
  ],

  sockets = [
    (name = "http", address = "*:8787", http = (), service = "d1-runtime"),
  ],
);

const d1RuntimeWorker :Workerd.Worker = (
  modules = [
    (name = "worker", esModule = embed "index.js"),
